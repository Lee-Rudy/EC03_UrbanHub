# ── Application ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8002
APP_ENV=development          # development | production

# ── Kafka ──────────────────────────────────────────────────────
# Adresse du broker Kafka (dans Docker : kafka:9092)
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_OUTPUT=traffic_events_normalized

# ── MongoDB ────────────────────────────────────────────────────
# URI de connexion MongoDB (dans Docker : mongodb://mongodb:27017)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=urbanhub_collecte

# ── Authentification des capteurs ──────────────────────────────
# Chemin vers le fichier JSON contenant les clés API des capteurs
API_KEYS_CONFIG_PATH=./config/api_keys.json

# ── RGPD ───────────────────────────────────────────────────────
DATA_RETENTION_DAYS=30
LOG_LEVEL=INFO
